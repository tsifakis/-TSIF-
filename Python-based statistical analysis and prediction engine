        ranked, df_all, mf_min=int(TSIF_MIN), max_abs=int(MAX_TSIF), TSIF_BAND=int(TSIF_BAND))
    top5_r3, _ = tsifakis_rule_3(series_list, df_all=df_all, topk=5)
