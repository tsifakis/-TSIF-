    print()
    print(f"TSIF rule 3: {top5_r3}")
    print(f"TSIF rule 4: {top5_r4}")
    print(f"TSIF rule 5: {top5_r5}")
    print(f"TSIF rule 6: {rule6_str}")
    print(f"TSIF rule 7: {rule7_str}\n")
    print("TSIF rule 8 Top-3: [" + ", ".join(f"\033[95m{n}\033[0m" for n in top3_r8) + "]")
    print("TSIF rule 8 Top-2:  [" + ", ".join(f"\033[94m{n}\033[0m" for n in top2_r8) + "]")
    green = "\033[92m"
    reset = "\033[0m"
    top1_disp = f"{green}{top1_r8[0]}{reset}" if top1_r8 else ""
    print(f"TSIF rule 8 Top-1:    [{top1_disp}]")

